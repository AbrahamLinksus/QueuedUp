generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  LEETCODE
  OTHER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemStatus {
  ACTIVE_REVIEW
  MASTERED
}

enum ReviewStatus {
  PENDING
  DONE
  SKIPPED
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  passwordHash      String
  createdAt         DateTime           @default(now())
  problems          Problem[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Problem {
  id         String        @id @default(cuid())
  title      String
  url        String
  platform   Platform      @default(OTHER)
  difficulty Difficulty
  status     ProblemStatus @default(ACTIVE_REVIEW)
  createdAt  DateTime      @default(now())
  userId     String

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags             Tag[]
  entries          Entry[]
  reviews          Review[]
  flashcardReviews FlashcardReview[]
}

model Entry {
  id          String   @id @default(cuid())
  problemId   String
  notes       String
  codeSnippet String
  codeLanguage String  @default("plaintext")

  timeComplexity  String?
  spaceComplexity String?

  timeTakenMinutes Int?
  attemptsCount    Int  @default(1)

  createdAt DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

model Tag {
  id       String  @id @default(cuid())
  name     String  @unique
  isPreset Boolean @default(false)

  problems Problem[]
}

model Review {
  id          String       @id @default(cuid())
  problemId   String
  scheduledFor DateTime
  dayOffset   Int
  status      ReviewStatus @default(PENDING)
  completedAt DateTime?

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([scheduledFor, status])
}

model SheetProblem {
  id         String @id @default(cuid())
  title      String
  url        String @unique
  difficulty String
  topic      String
  order      Int    @unique
}

model FlashcardReview {
  id         String   @id @default(cuid())
  problemId  String
  reviewedAt DateTime @default(now())
  recalledOk Boolean

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}
